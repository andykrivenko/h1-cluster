# H1 Light Worker — Environment Configuration
# Copy this file to .env and fill in your values

# NATS cluster servers (Heavy servers, comma-separated)
NATS_SERVERS=nats://192.168.XX.11:4222,nats://192.168.XX.12:4222

# NATS authentication token (must match Heavy server config)
NATS_TOKEN=your_secret_token_here

# Worker identifier (defaults to computer name)
WORKER_ID=light-worker-1

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=C:\H1_Node\logs\worker.log
