# H1 Heavy Server — Environment Configuration
# Copy this file to .env and fill in your values

# ─── NATS ─────────────────────────────────────────────────────────────────────
# NATS cluster servers (comma-separated)
NATS_SERVERS=nats://192.168.XX.11:4222,nats://192.168.XX.12:4222

# NATS authentication token (must match nats-server.conf)
NATS_TOKEN=your_secret_token_here

# ─── Logging ──────────────────────────────────────────────────────────────────
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── hh_expert MCP Bridge ─────────────────────────────────────────────────────
# Path to hh_expert/server.py (MCP server)
HH_EXPERT_PY=C:\path\to\hh_expert\server.py

# Python interpreter to use for hh_expert
HH_EXPERT_PYTHON=python

# Working directory for hh_expert process
HH_EXPERT_WORKDIR=C:\path\to\hh_expert
